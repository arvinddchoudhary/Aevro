{
  "name": "aevro-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "auth:cleanup": "tsx scripts/cleanup-auth.ts",
    "db:seed": "tsx prisma/seed.ts",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "prisma:format": "prisma format",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "start:prod": "node dist/main.js",
    "test": "tsx --test src/auth/**/*.spec.ts src/users/**/*.spec.ts src/location/**/*.spec.ts src/shiprocket/*.spec.ts src/shiprocket/**/*.spec.ts src/products/**/*.spec.ts src/reviews/*.spec.ts src/admin/**/*.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.0.0",
    "@nestjs/common": "latest",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "latest",
    "@nestjs/platform-fastify": "latest",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "fastify-raw-body": "^5.0.0",
    "google-auth-library": "^10.7.0",
    "pg": "^8.22.0",
    "reflect-metadata": "latest",
    "rxjs": "latest"
  },
  "devDependencies": {
    "@nestjs/cli": "latest",
    "@nestjs/schematics": "latest",
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "source-map-support": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
